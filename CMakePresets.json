{
  "version": 6,

"configurePresets": [
{
  "name": "default",
  "displayName": "tests simulations, for general CI runs to check Gemini3D code changes",
  "generator": "Ninja",
  "binaryDir": "build",
  "cacheVariables": {
    "gemini3d_python": true,
    "gemini3d_matlab": false,
    "package": false,
    "equil": false,
    "gemini3d_plot": false,
    "CMAKE_BUILD_TYPE": "Release",
    "CMAKE_COMPILE_WARNING_AS_ERROR": false,
    "CMAKE_LINK_WARNING_AS_ERROR": true
  }
},
{
  "name": "matlab", "inherits": "default",
  "displayName": "Prepare Gemini3D CI suite, using MatGemini if available",
  "cacheVariables": {
    "gemini3d_python": false,
    "gemini3d_matlab": true
  }
},
{
  "name": "debug", "inherits": "default",
  "displayName": "Debug build with bounds checking",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "Debug"
  }
},
{
  "name": "reldebug", "inherits": "default",
  "displayName": "Release with Debug Info bounds check",
  "cacheVariables": {
    "CMAKE_BUILD_TYPE": "RelWithDebInfo"
  }
},
{
  "name": "debug-sim-bounds", "inherits": "reldebug",
  "displayName": "Debug short simulations bounds check"
},
{
  "name": "nofind-sim-bounds", "inherits": "debug-sim-bounds",
  "displayName": "Debug short simulations bounds check, but don't find auto-build packages like HDF5",
  "cacheVariables": {
    "FETCHCONTENT_TRY_FIND_PACKAGE_MODE": "NEVER"
  }
},
{
  "name": "regen", "inherits": "default",
  "displayName": "Create .zst reference data, using Python if available",
  "cacheVariables": {
    "equil": true,
    "package": true
  }
},
{
  "name": "regen-matlab", "inherits": "regen",
  "displayName": "Create .zst reference data, using Matlab if available",
  "cacheVariables": {
    "gemini3d_python": false,
    "gemini3d_matlab": true
  }
}
],
"buildPresets": [
  { "name": "default", "configurePreset": "default", "configuration": "Release" },
  { "name": "regen", "configurePreset": "regen" },
  { "name": "regen-matlab", "configurePreset": "regen-matlab" },
  { "name": "reldebug", "inherits": "default", "configurePreset": "reldebug", "configuration": "RelWithDebInfo" },
  { "name": "debug", "inherits": "default", "configurePreset": "debug", "configuration": "Debug" },
  { "name": "debug-sim-bounds", "inherits": "reldebug", "configurePreset": "debug-sim-bounds" },
  { "name": "nofind-sim-bounds", "inherits": "debug-sim-bounds", "configurePreset": "nofind-sim-bounds" }

],
"testPresets": [
{
  "name": "default",
  "configurePreset": "default",
  "configuration": "Release",
  "output": {
    "outputOnFailure": true,
    "verbosity": "default"
  },
  "execution": {
    "noTestsAction": "error",
    "scheduleRandom": true,
    "stopOnFailure": false
  }
},
{
  "name": "reldebug", "inherits": "default",
  "configurePreset": "reldebug",
  "configuration": "RelWithDebInfo",
  "displayName": "Release with Debug Info"
},
{
  "name": "debug", "inherits": "default",
  "configurePreset": "debug",
  "configuration": "Debug",
  "displayName": "Debug test with bounds checking"
},
{
  "name": "debug-sim-bounds", "inherits": "reldebug",
  "configurePreset": "debug-sim-bounds",
  "displayName": "Debug short simulations bounds check",
  "filter": {
    "include": { "name": "run_bounds_check" },
    "exclude": { "name": "3D" }
  }
},
{ "name": "nofind-sim-bounds", "inherits": "debug-sim-bounds",
  "configurePreset": "nofind-sim-bounds",
  "displayName": "Debug short simulations bounds check, but don't find auto-build packages like HDF5"
},
{
  "name": "download", "inherits": "default",
  "displayName": "download reference data for subsequent offline tests",
  "description": "download with login HPC node for batch / interactive HPC offline tests",
  "filter": {
    "include": {"name": "download"}
  }
},
{
  "name": "offline", "inherits": "default",
  "displayName": "Run tests without network access",
  "filter": {
    "exclude": {"name": "internetConnectivity", "fixtures": {"setup": "internet_fxt"}}
  }
},
{
  "name": "setup", "inherits": "default",
  "filter": {"include": {"label": "setup"}}
},
{
  "name": "regen", "inherits": "default",
  "configurePreset": "regen",
  "displayName": "Python: create .zst reference data",
  "filter": {
    "exclude": {"label": "(compare|download|plot)", "fixtures": {"any": "(compare_fxt|inputOK_fxt|plot_fxt)"}}
  }
},
{
  "name": "regen-matlab", "inherits": "regen",
  "configurePreset": "regen-matlab",
  "displayName": "Matlab: create .zst reference data"
},
{
  "name": "compare-in", "inherits": "default",
  "filter": {
    "include": {"label": "compare", "name": "compare:input"}
  }
},
{
  "name": "compare-in-equil", "inherits": "default",
  "filter": {
    "include": {"label": "compare", "name": "compare:input:.*eq"}
  }
},
{
  "name": "compare-out", "inherits": "default",
  "filter": {
    "include": {"label": "compare", "name": "compare:output"},
    "exclude": {"fixtures": {"any": "run_fxt"}}
  }
}
],
"workflowPresets": [
  {
    "name": "default",
    "displayName": "tests simulations, for general CI runs to check Gemini3D code changes",
    "steps": [
      { "type": "configure", "name": "default" },
      { "type": "build", "name": "default" },
      { "type": "test", "name": "default" }
    ]
  },
  {
    "name": "debug-sim-bounds",
    "displayName": "Debug short simulations bounds check",
    "steps": [
      { "type": "configure", "name": "debug-sim-bounds" },
      { "type": "build", "name": "debug-sim-bounds" },
      { "type": "test", "name": "debug-sim-bounds" }
    ]
  },
  { "name": "nofind-sim-bounds",
    "displayName": "Short simulations bounds check, but don't find auto-build packages like HDF5",
    "steps": [
      { "type": "configure", "name": "nofind-sim-bounds" },
      { "type": "build", "name": "nofind-sim-bounds" },
      { "type": "test", "name": "nofind-sim-bounds" }
    ]
  },
  {
    "name": "regen",
    "displayName": "Python: create .zst reference data",
    "steps": [
      { "type": "configure", "name": "regen" },
      { "type": "build", "name": "regen" },
      { "type": "test", "name": "regen" }
    ]
  },
  {
    "name": "regen-matlab",
    "displayName": "Matlab: create .zst reference data",
    "steps": [
      { "type": "configure", "name": "regen-matlab" },
      { "type": "build", "name": "regen-matlab" },
      { "type": "test", "name": "regen-matlab" }
    ]
  }
]
}
